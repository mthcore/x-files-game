# Default: LF line endings for source code
*               text=auto eol=lf

# C++ / C
*.h             text eol=lf
*.hpp           text eol=lf
*.c             text eol=lf
*.cc            text eol=lf
*.cp            text eol=lf
*.cpp           text eol=lf

# Python
*.py            text eol=lf
*.pyi           text eol=lf

# Build / config
*.cmake         text eol=lf
CMakeLists.txt  text eol=lf
*.toml          text eol=lf
*.yaml          text eol=lf
*.yml           text eol=lf
*.json          text eol=lf
*.md            text eol=lf

# Binary fixtures
*.hdb           binary
*.HDB           binary
*.db            binary
*.sqlite        binary
*.pyc           binary
*.png           binary
*.jpg           binary

# Generated archives
*.zip           binary
*.gz            binary
*.tar           binary
